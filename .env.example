# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/campus_study
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Application Configuration
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000

# Firebase Cloud Messaging (FCM)
# Set to 'true' to enable push notifications
FCM_ENABLED=true
FCM_SERVICE_ACCOUNT_BASE64=your_base64_json_here

# Phase 5 - Monitoring & Scaling
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379

# Upload & Cache
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png
QR_CACHE_ENABLED=true

# Multi-tenancy
TENANT_HEADER_NAME=X-Tenant-ID

# Phase 6 - Release & Demo
RELEASE_REGISTRY=ghcr.io
CR_PAT=your_github_pat_here
DEMO_ADMIN_PASSWORD=change_me_in_ci
BACKUP_S3_PREFIX=s3://your-bucket/campus-hub-backups
BACKUP_RETENTION_DAYS=14
